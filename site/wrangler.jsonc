{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rc-9",
  "compatibility_date": "2025-04-28",
  "main": "worker/index.js",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash",
    "binding": "ASSETS"
  },
  "observability": { "enabled": true }
}
